<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_ai_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting for AI button"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_photo_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Photo: no packet yet"
            android:textSize="13sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="8dp"
            android:background="#111111">

            <ImageView
                android:id="@+id/iv_ai_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="AI photo"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_photo_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="24dp"
                android:text="Press AI on the glasses to receive a photo packet"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_audio_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Recordings: -"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_refresh_media"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Refresh photo and audio list" />

        <TextView
            android:id="@+id/tv_latest_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Latest photo: -"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_latest_audio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Latest audio: -"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
